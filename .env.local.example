# Claude API (required)
ANTHROPIC_API_KEY=sk-ant-...

# Scraping — optional, plain fetch fallback used if absent
FIRECRAWL_API_KEY=fc-...

# Email via Resend (required for email delivery)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=reports@ammodus.com
ADMIN_EMAIL=aminelamarti10@gmail.com

# Notion CRM — optional, silently skipped if absent
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=...

# Calendly booking link — shown in email CTA and results page
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/ammodus/discovery-call

# Enrichment — all optional, silently skipped if absent

# Tavily web search — used to detect hiring signals and tech/software adoption
# Get a free key at: https://tavily.com
TAVILY_API_KEY=tvly-...

# Companies House — used to look up company age, type, and officer count
# Free key at: https://developer.company-information.service.gov.uk/get-started
# Works without a key (rate-limited) but a key gives higher rate limits
COMPANIES_HOUSE_API_KEY=
